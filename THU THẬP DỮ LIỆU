 không thể loại bỏ trùng lặp theo ID.\")\n","\n","    # Chuẩn hóa Hệ tọa độ (CRS) sang EPSG:4326\n","    if gdf.crs is None:\n","        gdf.set_crs(epsg=4326, inplace=True)\n","        print(f\"\\nĐã thiết lập hệ tọa độ mặc định cho {id_col}: EPSG:4326\")\n","    elif str(gdf.crs) != \"EPSG:4326\":\n","        gdf = gdf.to_crs(epsg=4326)\n","        print(f\"\\nĐã chuyển đổi hệ tọa độ của {id_col} sang: EPSG:4326\")\n","    else:\n","        print(f\"\\nHệ tọa độ hiện tại của {id_col} đã là: {gdf.crs}\")\n","\n","    # Sửa chữa các hình học không hợp lệ\n","    initial_invalid_geometries = gdf.geometry.apply(lambda x: not x.is_valid).sum()\n","    if initial_invalid_geometries > 0:\n","        print(f\"\\nTìm thấy {initial_invalid_geometries} hình học không hợp lệ trong {id_col}. Đang sửa chữa...\")\n","        gdf['geometry'] = gdf.geometry.apply(lambda x: make_valid(x) if not x.is_valid else x)\n","        repaired_invalid_geometries = gdf.geometry.apply(lambda x: not x.is_valid).sum()\n","        if repaired_invalid_geometries == 0:\n","            print(\"Tất cả hình học không hợp lệ đã được sửa chữa thành công.\")\n","        else:\n","            print(f\"Còn lại {repaired_invalid_geometries} hình học không hợp lệ sau khi sửa chữa.\")\n","    else:\n","        print(\"\\nTất cả hình học đều hợp lệ.\")\n","\n","    print(f\"\\n--- Kết quả tiền xử lý cho {id_col} ---\")\n","    display(gdf.head())\n","    return gdf\n"],"execution_count":17,"outputs":[]},{"cell_type":"markdown","metadata":{"id":"253c2150"},"source":["### 8.1 Tiền xử lý POIs (POIs chính - `pois_gdf`)"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":0},"collapsed":true,"id":"e953a130","executionInfo":{"status":"ok","timestamp":1779072861825,"user_tz":-420,"elapsed":70,"user":{"displayName":"Hoa Bùi Thị Lệ","userId":"00828821152730244881"}},"outputId":"4cb2d14e-48c3-43aa-826f-80719de669d8"},"source":["pois_gdf = preprocess_gdf_osmnx(pois_gdf, id_col='osmid'