eoms:\n","            lines.append({'geometry': geom, 'osm_id': row.osm_id, 'fclass': row.fclass, 'name': row.name})\n","    else:\n","        lines.append({'geometry': row.geometry, 'osm_id': row.osm_id, 'fclass': row.fclass, 'name': row.name})\n","\n","roads_single_lines = gpd.GeoDataFrame(lines, crs=roads.crs)\n","\n","# Tạo đồ thị từ các LineString\n","G = nx.Graph()\n","\n","# Thêm các cạnh (edges) vào đồ thị\n","for idx, row in roads_single_lines.iterrows():\n","    geom = row.geometry\n","    if geom and geom.geom_type == 'LineString':\n","        # Lấy tọa độ điểm đầu và điểm cuối của đoạn đường\n","        start_node = (geom.coords[0][0], geom.coords[0][1])\n","        end_node = (geom.coords[-1][0], geom.coords[-1][1])\n","\n","        # Tính chiều dài của đoạn đường\n","        length = geom.length  # Chiều dài tính bằng đơn vị của CRS (độ)\n","\n","        # Thêm cạnh vào đồ thị\n","        G.add_edge(start_node, end_node, geometry=geom, length=length, osm_id=row.osm_id, fclass=row.fclass, name=row.name)\n","\n","print(f\"Đồ thị được tạo với {G.number_of_nodes()} nút và {G.number_of_edges()} cạnh.\")"]},{"cell_type":"markdown","metadata":{"id":"f952b28a"},"source":["## 11. Vẽ bản đồ phân bố POIs và Roads"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"bb98c7d7"},"outputs":[],"source":["import folium\n","import geopandas as gpd\n","import os\n","\n","# Nạp lại dữ liệu nếu bị mất trong memory\n","if 'roads' not in locals():\n","    roads = gpd.read_file(\"/content/output/roads_nhatrang.shp\")\n","if 'pois_gdf' not in locals():\n","    pois_gdf = gpd.read_file(\"/content/output/pois_nhatrang.shp\")\n","\n","# Đảm bảo roads_single_lines tồn tại\n","if 'roads_single_lines' not in locals():\n","    lines = []\n","    for _, row in roads.iterrows():\n","        if row.geometry.geom_type == 'MultiLineString':\n","            for geom in row.geometry.geoms:\n","                lines.append({'geometry': geom, 'osm_id': row.osm_id, 'fclass': row.fclass, 'name': row.name})\n","        else:\n","            lines.append({'geometry': row.geometry, 'osm_id': row.osm_id, 'fclass': row.fclass, 'name': row.name})\n","    roads_single_lines = gpd.GeoDataFrame(lines, crs=roads.crs)\n","\n","# Lấy tọa độ trung tâm Nha Trang\n","center_lat, center_lon = 12.245, 109.194\n","m = folium.Map(location=[center_lat, center_lon], zoom_start=13)\n","\n","# Vẽ mẫu 1000 đoạn đường và 500 POIs để tránh treo trình duyệt\n","roads_sample = roads_single_lines.sample(n=min(1000, len(roads_single_lines)))\n","pois_sample = pois_gdf.sample(n=min(500, len(pois_gdf)))\n","\n","folium.GeoJson(\n","    roads_sample.to_json(),\n","    name='Roads Sample',\n","    style_function=lambda feature: {'color': 'gray', 'weight': 2}\n",").add_to(m)\n","\n","for _, row in pois_sample.iterrows():\n","    folium.CircleMarker(\n","        location=[row.geometry.y, row.geometry.x],\n","        radius=3, color='blue', fill=True, popup=row['fclass']\n","    ).add_to(m)\n","\n","display(m)"]},{"cell_type":"markdown","metadata":{"id":"b0bf68bc"},"source":["## 12. Tìm đường đi ngắn nhất và hiển thị trên bản đồ"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"687ffdc6"},"outputs":[],"source":["from scipy.spatial import cKDTree\n","import networkx as nx\n","import numpy as np\n","import folium\n","\n","# 1. Đảm bảo đồ thị G tồn tại và lấy thành phần kết nối lớn nhất\n","if 'G' not in locals() or G is None:\n","    print(\"Đang xây dựng đồ thị mạng lưới đường...\")\n","    G = nx.Graph()\n","    for idx, row in roads_single_lines.iterrows():\n","        geom = row.geometry\n","        if geom and geom.geom_type == 'LineString':\n","            start_node = (geom.coords[0][0], geom.coords[0][1])\n","            end_node = (geom.coords[-1][0], geom.coords[-1][1])\n","            G.add_edge(start_node, end_node, length=geom.length)\n","\n","# Lọc lấy thành phần kết nối lớn nhất để đảm bảo có đường đi giữa các nút\n","largest_cc = max(nx.connected_components(G), key=len)\n","G_sub = G.subgraph(largest_cc).copy()\n","print(f\"Đồ thị gốc: {G.number_of_nodes()} nút. Đồ thị kết nối lớn nhất: {G_sub.number_of_nodes()} nút.\")\n","\n","# 2. Lọc POIs trong Nha Trang\n","nt_lat_min, nt_lat_max = 12.18, 12.32\n","nt_lon_min, nt_lon_max = 109.15, 109.25\n","pois_nhatrang = pois_gdf[(pois_gdf['lat'] \u003e nt_lat_min) \u0026 (pois_gdf['lat'] \u003c nt_lat_max) \u0026 (pois_gdf['lon'] \u003e nt_lon_min) \u0026 (pois_gdf['lon'] \u003c nt_lon_max)]\n","\n","# 3. Hàm tìm nút gần nhất thuộc đồ thị con G_sub\n","def find_nearest_node_in_subgraph(graph, point_geom):\n","    nodes = list(graph.nodes())\n","    node_coords = np.array(nodes)\n","    tree = cKDTree(node_coords)\n","    _, idx = tree.query([point_geom.x, point_geom.y])\n","    return nodes[idx]\n","\n","# Chọn 2 POI bất kỳ từ danh sách Nha Trang\n","start_poi = pois_nhatrang.iloc[0]\n","end_poi = pois_nhatrang.iloc[min(20, len(pois_nhatrang)-1)]\n","\n","origin_node = find_nearest_node_in_subgraph(G_sub, start_poi.geometry)\n","destination_node = find_nearest_node_in_subgraph(G_sub, end_poi.geometry)\n","\n","try:\n","    # 4. Tìm đường đi ngắn nhất trên G_sub\n","    shortest_path = nx.shortest_path(G_sub, source=origin_node, target=destination_node, weight='length')\n","    path_coords = [(node[1], node[0]) for node in shortest_path]\n","\n","    # 5. Vẽ bản đồ\n","    m_shortest = folium.Map(location=[start_poi.geometry.y, start_poi.geometry.x], zoom_start=14)\n","    folium.PolyLine(path_coords, color=\"blue\", weight=5, opacity=0.7, popup=\"Lộ trình tối ưu\").add_to(m_shortest)\n","\n","    folium.Marker([start_poi.geometry.y, start_poi.geometry.x], popup=f\"Điểm đi: {start_poi['name']}\", icon=folium.Icon(color='green')).add_to(m_shortest)\n","    folium.Marker([end_poi.geometry.y, end_poi.geometry.x], popup=f\"Điểm đến: {end_poi['name']}\", icon=folium.Icon(color='red')).add_to(m_shortest)\n","\n","    display(m_shortest)\n","    print(f\"Thành công! Đã tìm thấy đường đi từ {start_poi['name']} đến {end_poi['name']}.\")\n","\n","except Exception as e:\n","    print(f\"Lỗi: {e}\")"]}],"metadata":{"colab":{"authorship_tag":"ABX9TyO11CCO2uqtPbEXDDOv/d29","name":"","version":""},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}