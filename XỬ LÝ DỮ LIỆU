, lon từ geometry để kiểm tra\n","pois_gdf['lat'] = pois_gdf.geometry.y\n","pois_gdf['lon'] = pois_gdf.geometry.x\n","\n","# kiểm tra tọa độ ngoài phạm vi địa lý hợp lệ (-90 đến 90 cho lat, -180 đến 180 cho lon)\n","invalid_range = pois_gdf[\n","    (pois_gdf[\"lat\"] \u003c -90) | (pois_gdf[\"lat\"] \u003e 90) |\n","    (pois_gdf[\"lon\"] \u003c -180) | (pois_gdf[\"lon\"] \u003e 180)\n","]\n","\n","# kiểm tra giá trị rỗng trong lat/lon\n","null_coords = pois_gdf[pois_gdf[\"lat\"].isnull() | pois_gdf[\"lon\"].isnull()]\n","\n","# kiểm tra tọa độ (0,0) thường là giá trị mặc định hoặc lỗi\n","zero_coords = pois_gdf[(pois_gdf[\"lat\"] == 0) \u0026 (pois_gdf[\"lon\"] == 0)]\n","\n","# In số lượng bản ghi có tọa độ NULL.\n","print(\"Số bản ghi có tọa độ NULL:\", len(null_coords))\n","print(\"Số bản ghi có tọa độ (0,0):\", len(zero_coords))\n","print(\"Số bản ghi có tọa độ ngoài phạm vi địa lý hợp lệ:\", len(invalid_range))\n","if not invalid_range.empty:\n","    display(invalid_range.head())\n","\n","# bounding box khu vực nghiên cứu (Nha Trang)\n","lat_min = 12.1428752\n","lat_max = 109.112878\n","lon_min = 12.3799085\n","lon_max = 109.3714549\n","\n","# Tạo một GeoDataFrame 'outside_area' chứa các bản ghi có tọa độ nằm ngoài hộp giới hạn của khu vực nghiên cứu.\n","outside_area = pois_gdf[\n","    (pois_gdf[\"lat\"] \u003c lat_min) | (pois_gdf[\"lat\"] \u003e lat_max) |\n","    (pois_gdf[\"lon\"] \u003c lon_min) | (pois_gdf[\"lon\"] \u003e lon_max)\n","]\n","\n","print(\"Số bản ghi ngoài khu vực nghiên cứu:\", len(outside_area))\n","\n","# Loại bỏ các bản ghi có tọa độ không hợp lệ hoặc nằm ngoài khu vực nghiên cứu\n","initial_count_for_coord_filter = len(pois_gdf)\n","# Lọc 'pois_gdf' để chỉ giữ lại các bản ghi có tọa độ hợp lệ và nằm trong khu vực nghiên cứu.\n","pois_gdf = pois_gdf[\n","    ~((pois_gdf[\"lat\"] \u003c -90) | (pois_gdf[\"lat\"] \u003e 90) | # Ngoài phạm vi vĩ độ chuẩn\n","      (pois_gdf[\"lon\"] \u003c -180) | (pois_gdf[\"lon\"] \u003e 180) | # Ngoài phạm vi kinh độ chuẩn\n","      (pois_gdf[\"lat\"].isnull()) | (pois_gdf[\"lon\"].isnull()) | # Tọa độ rỗng\n","      ((pois_gdf[\"lat\"] == 0) \u0026 (pois_gdf[\"lon\"] == 0)) | # Tọa độ (0,0)\n","      (pois_gdf[\"lat\"] \u003c lat_min) | (pois_gdf[\"lat\"] \u003e lat_max) | # Ngoài vĩ độ khu vực nghiên cứu\n","      (pois_gdf[\"lon\"] \u003c lon_min) | (pois_gdf[\"lon\"] \u003e lon_max)) # Ngoài kinh độ khu vực nghiên cứu\n","]\n","print(f\"Đã loại bỏ {initial_count_for_coord_filter - len(pois_gdf)} bản ghi có tọa độ không hợp lệ hoặc ngoài khu vực.\")\n","\n","#=== Loại bỏ các bản ghi trùng lặp dựa trên osm_id trong pois_gdf ===\n","initial_pois_count = len(pois_gdf)\n","pois_gdf = pois_gdf.drop_duplicates(subset=['osm_id'])\n","# In số lượng bản ghi trùng lặp đã được loại bỏ.\n","print(f\"\\nĐã loại bỏ {initial_pois_count - len(pois_gdf)} bản ghi trùng lặp trong pois_gdf.\")\n","\n","#=== Chuẩn hóa Hệ tọa độ (CRS) sang EPSG:4326 (WGS84) nếu chưa đúng cho pois_gdf ===\n","if pois_gdf.crs is None:\n","    pois_gdf.set_crs(epsg=4326, inplace=True)\n","    print(\"\\nĐã thiết lập hệ tọa độ mặc định cho pois_gdf: EPSG:4326\")\n","else:\n","    pois_gdf = pois_gdf.to_crs(epsg=4326)\n","    print(f\"\\nHệ tọa độ hiện tại của pois_gdf: {pois_gdf.crs}\")\n","\n","#=== Hiển thị kết quả sau khi làm sạch pois_gdf ===\n","display(pois_gdf.head())"]},{"cell_type":"markdown","metadata":{"id":"j3nVlUJTZ9VL"},"source":["## 6. CHUẨN HOÁ DỮ LIỆU ROADS\n"]},{"cell_type":"markdown","metadata":{"id":"b0a45dbb"},"source":["### Chuẩn hóa tên thuộc tính (cột)\n","\n","Chuyển đổi tất cả tên cột về dạng chữ thường và thay thế khoảng trắng bằng dấu gạch dưới để dễ dàng truy cập và nhất quán."]},{"cell_type":"code","execution_count":9,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":275},"executionInfo":{"elapsed":309,"status":"ok","timestamp":1779072953710,"user":{"displayName":"Hoa Bùi Thị Lệ","userId":"00828821152730244881"},"user_tz":-420},"id":"685484b5","outputId"